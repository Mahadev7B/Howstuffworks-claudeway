# Anthropic API — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model (Sonnet is the best cost/quality ratio for this use case)
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI TTS (optional — falls back to browser Web Speech if empty)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Cost guardrails
DAILY_BUDGET_USD=5.00
MAX_COST_PER_LESSON_USD=0.15
PER_IP_HOURLY_LIMIT=20

# Cache TTL (0 = never expire)
LESSON_CACHE_TTL_DAYS=30

# Image generation: "matplotlib" (free, schematic) or "flux" (paid, photoreal)
IMAGE_PROVIDER=matplotlib
FAL_API_KEY=
FLUX_MODEL=fal-ai/flux/schnell
FLUX_IMAGE_SIZE=landscape_16_9

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
PORT=5000

# Admin (set a strong secret to enable /admin/clear-cache)
ADMIN_SECRET=
